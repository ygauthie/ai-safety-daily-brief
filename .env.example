# LLM Provider: "openrouter" (default) or "anthropic"
LLM_PROVIDER=openrouter

# Required for OpenRouter (default provider)
OPENROUTER_API_KEY=sk-or-...

# Required only if LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...

# Optional: GitHub token for higher API rate limits
GITHUB_TOKEN=ghp_...

# Optional: Override LLM model
# For OpenRouter: anthropic/claude-sonnet-4 (default)
# For Anthropic: claude-sonnet-4-6
LLM_MODEL=anthropic/claude-sonnet-4
